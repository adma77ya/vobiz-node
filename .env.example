# Vobiz API Credentials
# Get these from https://console.vobiz.ai
VOBIZ_AUTH_ID=your_auth_id
VOBIZ_AUTH_TOKEN=your_auth_token

# Default phone numbers (can be overridden in the UI)
# Must include country code, e.g. +911234567890
FROM_NUMBER=+91xxxxxxxxxx
TO_NUMBER=+91xxxxxxxxxx

# Server ports
PORT=3000
WEBHOOK_PORT=5678
